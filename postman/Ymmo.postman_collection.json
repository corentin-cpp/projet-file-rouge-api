          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) pm.collectionVariables.set('agencyId', res.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/agencies",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ymmo Paris\",\n  \"siret\": \"12345678901234\",\n  \"email\": \"contact@ymmo-paris.fr\",\n  \"phone\": \"0140000000\",\n  \"address\": \"10 Rue de la Paix\",\n  \"city\": \"Paris\",\n  \"postalCode\": \"75001\",\n  \"country\": \"FR\"\n}"
            }
          }
        },
        {
          "name": "Get Agency",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/agencies/{{agencyId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Agency",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/agencies/{{agencyId}}",
            "header": [
