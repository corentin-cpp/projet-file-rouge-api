            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0140000001\"\n}"
            }
          }
        },
        {
          "name": "Delete Agency",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/agencies/{{agencyId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
